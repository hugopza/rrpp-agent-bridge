RRPP_DATABASE_PATH=var/rrpp-bridge.db
RRPP_MODE=shadow
RRPP_DASHBOARD_USER=admin
RRPP_DASHBOARD_PASSWORD=replace-with-a-long-random-password
RRPP_SESSION_SECRET=replace-with-at-least-32-random-characters
RRPP_HOST=127.0.0.1
RRPP_PORT=8080
RRPP_MAX_ATTEMPTS=3
RRPP_LEASE_SECONDS=60
RRPP_CANARY_SENDERS=test-user
RRPP_GMAIL_CLIENT_PATH=secrets/gmail-oauth-client.json
RRPP_GMAIL_TOKEN_PATH=secrets/gmail-token.json
RRPP_GMAIL_POLL_SECONDS=60
RRPP_GMAIL_BATCH_SIZE=50
RRPP_BACKUP_DIR=backups
RRPP_BACKUP_EXPORT_DIR=backup-export
RRPP_BACKUP_AGE_RECIPIENT=
RRPP_BACKUP_HOUR=3
RRPP_BACKUP_TIMEZONE=Europe/Madrid
RRPP_INSTAGRAM_ENABLED=false
RRPP_INSTAGRAM_PORT=8081
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_AGENT_ID=rrpp
OPENCLAW_TIMEOUT_SECONDS=60
OPENCLAW_GATEWAY_TOKEN=
